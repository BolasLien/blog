---
interface Props {
  prev?: { title: string; href: string };
  next?: { title: string; href: string };
}
const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="pagination" aria-label="Post navigation">
    {prev ? (
      <a href={prev.href} class="pagination-link pagination-prev">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
        <span>
          <span class="pagination-label">Previous</span>
          <span class="pagination-title">{prev.title}</span>
        </span>
      </a>
    ) : <div />}
    {next ? (
      <a href={next.href} class="pagination-link pagination-next">
        <span>
          <span class="pagination-label">Next</span>
          <span class="pagination-title">{next.title}</span>
        </span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </a>
    ) : <div />}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 0;
    border-top: 1px solid var(--border);
    margin-top: 24px;
  }
  .pagination-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    max-width: 45%;
    text-decoration: none;
    color: var(--fg-2);
    transition: color 120ms ease;
  }
  .pagination-link:hover { color: var(--accent); }
  .pagination-next { text-align: right; }
  .pagination-link span {
    display: flex;
    flex-direction: column;
  }
  .pagination-label {
    font-size: 12px;
    color: var(--fg-3);
  }
  .pagination-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--fg-1);
    margin-top: 2px;
    line-height: 1.3;
  }
  .pagination-link:hover .pagination-title { color: var(--accent); }
</style>
