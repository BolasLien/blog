---
type NavItem = 'Posts' | 'Tags' | 'Archives' | 'About';

interface Props {
  activeNav?: NavItem;
}
const { activeNav } = Astro.props;

const navItems: { label: NavItem; href: string }[] = [
  { label: 'Posts',    href: '/blog/' },
  { label: 'Tags',     href: '/blog/tags/' },
  { label: 'Archives', href: '/blog/archives/' },
  { label: 'About',    href: '/blog/about/' },
];
---

<header class="site-header">
  <a href="/blog/" class="wordmark" aria-label="bolas 的部落格">
    bolas<span class="wordmark-accent">;</span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    {navItems.map(({ label, href }) => (
      <a
        href={href}
        class:list={['nav-link', { 'nav-active': activeNav === label }]}
        aria-current={activeNav === label ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </nav>

  <div class="header-actions">
    <a href="/blog/rss.xml" class="icon-btn" title="RSS" aria-label="RSS 訂閱">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11a9 9 0 0 1 9 9"/>
        <path d="M4 4a16 16 0 0 1 16 16"/>
        <circle cx="5" cy="19" r="1.5"/>
      </svg>
    </a>
    <button id="theme-toggle" class="icon-btn" title="切換主題" aria-label="切換深淺色主題">
      <!-- moon (shown in light mode) -->
      <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"/>
      </svg>
      <!-- sun (shown in dark mode) -->
      <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
      </svg>
    </button>
  </div>
</header>

<script>
  function applyThemeIcons(theme: string) {
    const moon = document.getElementById('icon-moon');
    const sun  = document.getElementById('icon-sun');
    if (!moon || !sun) return;
    moon.style.display = theme === 'dark' ? 'none' : '';
    sun.style.display  = theme === 'dark' ? ''     : 'none';
  }

  function initTheme() {
    const current = document.documentElement.getAttribute('data-theme') ?? 'light';
    applyThemeIcons(current);
  }

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    applyThemeIcons(next);
  });

  initTheme();
</script>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }

  /* Wordmark */
  .wordmark {
    font-family: var(--font-sans);
    font-weight: var(--fw-black);
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--fg-1);
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    flex-shrink: 0;
  }
  .wordmark:hover { color: var(--fg-1); }
  .wordmark-accent { color: var(--brand); }

  /* Nav */
  .site-nav {
    display: flex;
    gap: 22px;
  }
  .nav-link {
    font-size: 14px;
    color: var(--fg-1);
    text-decoration: none;
    transition: color 120ms ease;
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--denim-deep); }
  .nav-active {
    text-decoration: underline;
    text-decoration-style: wavy;
    text-decoration-thickness: 2px;
    text-underline-offset: 6px;
    text-decoration-color: var(--denim);
  }
  .nav-active:hover { color: var(--fg-1); }

  /* Icon actions */
  .header-actions {
    display: flex;
    gap: 4px;
    color: var(--fg-2);
    flex-shrink: 0;
  }
  .icon-btn {
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 5px;
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    transition: color 120ms ease, background 120ms ease;
    text-decoration: none;
  }
  .icon-btn:hover {
    color: var(--accent);
    background: var(--bg-2);
  }

  /* Mobile: hide some nav items if too cramped */
  @media (max-width: 480px) {
    .site-nav { gap: 14px; }
    .nav-link { font-size: 13px; }
  }
</style>
