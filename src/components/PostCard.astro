---
import Tag from './Tag.astro';
import { formatDateParams } from '../utils/dates';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  href: string;
}
const { title, date, description, tags, href } = Astro.props;
const { year, month, day } = formatDateParams(date);
const dateStr = `${year}-${month}-${day}`;
---

<article class="post-card">
  <div class="post-date">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5" width="18" height="16" rx="2"/>
      <path d="M8 3v4M16 3v4M3 10h18"/>
    </svg>
    <time datetime={`${year}-${month}-${day}`}>{dateStr}</time>
  </div>
  <h2 class="post-title">
    <a href={href} class="post-link">{title}</a>
  </h2>
  <p class="post-desc">{description}</p>
  {tags.length > 0 && (
    <div class="post-tags">
      {tags.map(t => <Tag name={t} />)}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
  }
  .post-date {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: var(--fg-3);
    font-family: var(--font-mono);
    margin-bottom: 4px;
  }
  .post-title {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.3;
    margin: 4px 0 8px;
  }
  .post-link {
    color: var(--fg-1);
    text-decoration: underline;
    text-decoration-style: dashed;
    text-decoration-color: var(--border);
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
    transition: color 120ms ease, text-decoration-color 120ms ease;
  }
  .post-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .post-desc {
    font-size: 14.5px;
    line-height: 1.75;
    color: var(--fg-2);
    margin: 0 0 10px;
  }
  .post-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
</style>
