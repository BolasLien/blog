---
interface Props {
  name: string;
  href?: string;
}
const { name, href = `/blog/tags/${name}/` } = Astro.props;
---

<a href={href} class="tag">#{name}</a>

<style>
  .tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    color: var(--denim-deep);
    background: var(--denim-soft);
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: background 120ms ease, color 120ms ease;
    white-space: nowrap;
  }
  .tag:hover {
    background: var(--denim-200);
    color: var(--denim-deep);
  }
</style>
