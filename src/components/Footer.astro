---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-socials">
    <a href="https://github.com/BolasLien" class="footer-icon" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.3.1 1.9 1.3 1.9 1.3 1.1 1.9 3 1.4 3.7 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6a4.7 4.7 0 0 1 1.2-3.2 4.3 4.3 0 0 1 .1-3.2s1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.4 1 .4 2.3.1 3.2a4.7 4.7 0 0 1 1.2 3.2c0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.2c0 .3.2.7.8.6A12 12 0 0 0 12 .3Z"/>
      </svg>
    </a>
    <a href="mailto:bolaslien@gmail.com" class="footer-icon" aria-label="Email">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="5" width="18" height="14" rx="2"/>
        <path d="m3 7 9 6 9-6"/>
      </svg>
    </a>
    <a href="/blog/rss.xml" class="footer-icon" aria-label="RSS">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11a9 9 0 0 1 9 9"/>
        <path d="M4 4a16 16 0 0 1 16 16"/>
        <circle cx="5" cy="19" r="1.5"/>
      </svg>
    </a>
  </div>
  <div class="footer-copy">© {year} Bolas Lien · Built with Astro</div>
</footer>

<style>
  .site-footer {
    margin-top: 48px;
    padding: 18px 0 32px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .footer-socials {
    display: flex;
    gap: 14px;
  }
  .footer-icon {
    color: var(--fg-3);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 120ms ease;
  }
  .footer-icon:hover { color: var(--accent); }
  .footer-copy {
    font-size: 13px;
    color: var(--fg-3);
  }
</style>
